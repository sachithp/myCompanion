# Anthropic
ANTHROPIC_API_KEY=your_api_key_here

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorised redirect URI to register: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Secrets — use a long random string for each (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string
SESSION_SECRET=change_this_to_another_long_random_string
